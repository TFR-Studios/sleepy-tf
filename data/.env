# Sleepy-TF 环境变量配置
# 优先级高于 config.yaml
# 配置文档: doc/config.md

# ===== 基本配置 =====
# 监听地址
sleepy_main_host = "0.0.0.0"

# 服务端口
sleepy_main_port = 9010

# 调试模式
sleepy_main_debug = "true"

# 时区
sleepy_main_timezone = "Asia/Shanghai"

# 密钥 (更新状态时需要，请勿泄露)
sleepy_main_secret = "Wnnz3tz!"

# ===== 页面配置 =====
# 你的名字
sleepy_page_name = "TF注册表"

# 页面标题
sleepy_page_title = "看看TF注册表在干嘛"

# 页面描述
sleepy_page_desc = "TF注册表的在线状态页面"

# ===== 状态配置 =====
# 网页刷新间隔 (毫秒)
sleepy_status_refresh_interval = 5000

# ===== 统计配置 =====
# 是否启用统计功能
sleepy_metrics_enabled = "true"

# ===== 插件配置 =====
# 启用的插件列表 (JSON 格式)
# sleepy_plugins_enabled = '["v4_compatible", "theme_detect"]'
