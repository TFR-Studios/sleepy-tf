{
  "name": "sleepy-tf",
  "version": "5.2.0",
  "description": "A Flask application to see if you're online or not.",
  "scripts": {
    "start": "python main.py",
    "dev": "powershell -Command \"$env:PYTHONUTF8=1; python main.py\"",
    "client": "python sleepy_client.py",
    "install-deps": "pip install -r requirements.txt",
    "install-client-deps": "pip install pynput pygetwindow requests",
    "update": "git pull && pip install -r requirements.txt"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/sleepy-project/sleepy.git"
  },
  "license": "MIT"
}
